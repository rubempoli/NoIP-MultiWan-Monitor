# noip-multiwan-monitor configuration example
# Author: Rubem Swensson
# Co-Authors: ChatGPT + Codex
# Changelog:
# - 2026-05-17: Added optional generic No-IP DDNS records for independent IP exposure.
# - 2026-05-17: Added DNS-based public IP detection fallback.
# - 2026-05-17: Added known ISP names cache for ISP detection before WHOIS lookup.
# - 2026-05-17: Made WHOIS ISP matching tolerant of accent and encoding differences.
# - 2026-05-17: Added optional WHOIS-based ISP detection fallback.
# - 2026-05-17: Renamed visible project references to multi-WAN.
# - 2026-05-17: Initial public configuration template.

# Hostname managed by No-IP/DDNS.
NOIP_HOSTNAME="realswensson.ddns.net"

# Runtime files.
STATUS_DIR="/var/lib/noip"
STATUS_FILE="${STATUS_DIR}/status.txt"
HISTORY_FILE="${STATUS_DIR}/history.log"
KNOWN_ISP_NAMES_FILE="${STATUS_DIR}/known-isp-names.conf"

# External IP providers are tried in order. Keep the list small and reliable.
PUBLIC_IP_ENDPOINTS="http://ip1.dynupdate.no-ip.com:8245 https://api.ipify.org"
PUBLIC_IP_TIMEOUT_SECONDS="10"

# DNS-based public IP providers are tried after HTTP providers.
# Format: query_name@resolver_ip
PUBLIC_IP_DNS_QUERIES="myip.opendns.com@208.67.222.222"
PUBLIC_IP_DNS_TIMEOUT_SECONDS="10"

# DNS resolver used to check the IP currently published for NOIP_HOSTNAME.
DNS_RESOLVER="1.1.1.1"

# Optional independent No-IP DDNS records.
# These are useful when you want to expose each No-IP record independently.
NOIP_DDNS_RESOLVER="${DNS_RESOLVER}"
NOIP_DDNS_01_NAME="primary"
NOIP_DDNS_01_HOSTNAME="realswensson.ddns.net"
NOIP_DDNS_02_NAME="main"
NOIP_DDNS_02_HOSTNAME="realswensson-main.ddns.net"
NOIP_DDNS_03_NAME="backup"
NOIP_DDNS_03_HOSTNAME="realswensson-bkp.ddns.net"

# Optional conservative ISP detection.
# Methods are tried in order. WHOIS should be used after local methods.
ISP_DETECTION_METHODS="known_isp_names,whois"

# Local learned IP-to-ISP map. Format: IP=ISP
# Example: 187.59.12.49=Vivo
ENABLE_WHOIS_KNOWN_ISP_NAMES_CACHE="true"

# Optional ISP detection by observed IPv4 prefixes.
# Format: ISP=prefix1,prefix2;ISP=prefix3
# Leave empty unless you want prefix rules before WHOIS.
ISP_PREFIX_RULES=""

# Optional ISP detection by WHOIS text match.
# Format: ISP=token1,token2;ISP=token3
# Use ASCII tokens broad enough to survive accents and terminal encoding differences.
WHOIS_COMMAND="whois"
WHOIS_TIMEOUT_SECONDS="15"
WHOIS_ISP_RULES="Vivo=TELEFONICA,TELEF,GVT,AS18881;Claro=CLARO,NET SERVICOS,EMBRATEL,AS28573"
UNKNOWN_ISP_LABEL="unknown"

# DUC restart integration is intentionally disabled by default.
ENABLE_DUC_RESTART="false"
DUC_SERVICE_NAME="noip-duc.service"
DUC_ENV_FILE="/etc/noip-duc.env"
DUC_BINARY="/usr/bin/noip-duc"

# Local API settings.
API_BIND_HOST="0.0.0.0"
API_PORT="8085"
API_HISTORY_DEFAULT_LINES="50"
API_HISTORY_MAX_LINES="500"
