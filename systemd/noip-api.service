# noip-dualwan-monitor API service
# Author: Rubem Swensson
# Co-Authors: ChatGPT + Codex
# Changelog:
# - 2026-05-17: Initial API service using the consolidated monitor configuration.

[Unit]
Description=No-IP Dual-WAN Monitor API
After=network.target

[Service]
Type=simple
Environment=NOIP_MONITOR_CONFIG=/etc/noip-monitor.conf
ExecStart=/usr/bin/python3 /usr/local/bin/noip-api.py
Restart=always
RestartSec=5
User=root

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/noip

[Install]
WantedBy=multi-user.target
